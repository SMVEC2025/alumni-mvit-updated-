# ─────────────────────────────────────────────────────────────────────────────
# SMVEC Alumni API — environment variables.
# Copy to `.env` for local dev. In production (Cloud Run) set these as the
# service's env vars / secrets — do NOT commit real values. Validated at boot by
# src/config/env.js; the server refuses to start if a required one is missing.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ──
NODE_ENV=production
# Cloud Run injects PORT=8080 automatically; only needed locally.
PORT=4000

# ── Database (MongoDB Atlas) ──
# mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/mvit_alumni?retryWrites=true&w=majority
MONGODB_URI=

# ── JWT secrets (generate fresh, ≥16 chars; use long random strings) ──
# e.g. openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# ── CORS — comma-separated allowed frontend origins (no trailing slash) ──
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com

# ── Auth cookie scoping (cross-subdomain in production) ──
# Frontend app.yourdomain.com + API api.yourdomain.com share the parent domain.
# Set COOKIE_DOMAIN to the parent (leading dot) and SameSite=None so the refresh
# cookie is sent on cross-site requests. Leave both empty/strict for local dev.
COOKIE_DOMAIN=.yourdomain.com
COOKIE_SAMESITE=none

# ── OTP provider ──
OTP_API_URL=https://your-otp-provider.example.com/send
OTP_API_AUTH_KEY=
OTP_TTL_SEC=300

# ── Cloudflare Turnstile (captcha on the login OTP request) ──
# Secret key from Cloudflare dashboard → Turnstile → your widget. The matching
# PUBLIC site key goes in the frontend as VITE_TURNSTILE_SITE_KEY. Leave empty to
# disable the captcha check; set it in production to protect SMS spend from bots.
TURNSTILE_SECRET_KEY=

# ── Contact-message encryption key (base64 of EXACTLY 32 bytes) ──
# Generate: openssl rand -base64 32
CONTACT_ENC_KEY=

# ── Admin allowlist (comma-separated mobile numbers granted admin role) ──
ADMIN_MOBILE_NUMBERS=

# ── SMTP (contact-form emails). Optional — leave blank to disable email. ──
SMTP_HOST=
SMTP_PORT=465
SMTP_USER_NOTIFY=
SMTP_PASS_NOTIFY=
SMTP_USER_ACK=
SMTP_PASS_ACK=
COORDINATOR_EMAIL=

# ── Object storage for image uploads (Cloudflare R2 / S3-compatible) ──
# Optional — leave blank to disable uploads (they'll 500 with a clear message).
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_BASE_URL=
