# SPA routing: send any path that isn't a real file/folder to index.html so React Router can resolve it on refresh.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Don't rewrite existing files (assets, images, etc.) or directories.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else falls through to the SPA entry.
  RewriteRule ^ index.html [L]
</IfModule>

# Long-cache hashed build assets (Vite emits content-hashed filenames under /assets/).
<IfModule mod_headers.c>
  <FilesMatch "\.(?:js|css|woff2?|ttf|otf|eot|png|jpe?g|gif|svg|webp|avif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # index.html must never be cached aggressively — it points at the latest hashed bundle.
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
